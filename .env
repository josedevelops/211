# Database (Postgres)
POSTGRES_USER=civic_user
POSTGRES_PASSWORD=civic_pass
POSTGRES_DB=civic_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# RabbitMQ
RABBITMQ_USER=civic_user
RABBITMQ_PASSWORD=civic_pass
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# App Environment
APP_ENV=development
SERVICE_PORT=8000

# Service URLs (internal-only)
# These match container names on the civic_net network
GATEWAY_URL=http://gateway:8000
REQUEST_SERVICE_URL=http://request-service:8000/api/v1/requests/
NOTIFICATION_SERVICE_URL=http://notification-service:8000
LOCATION_SERVICE_URL=http://location-service:8000/api/v1/validate/
TICKET_SERVICE_URL=http://ticket-service:8000

POSTGRES_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:${POSTGRES_PORT}/${POSTGRES_DB}
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@rabbitmq:${RABBITMQ_PORT}/
