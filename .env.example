# Database (Postgres)
# WARNING: Dev defaults only - change for production
POSTGRES_USER=civic_user
POSTGRES_PASSWORD=civic_pass
POSTGRES_DB=civic_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# RabbitMQ
# WARNING: Dev defaults only - change for production
RABBITMQ_USER=civic_user
RABBITMQ_PASSWORD=civic_pass
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# App Environment
APP_ENV=development
SERVICE_PORT=8000

# JWT
# WARNING: Must be changed for production
JWT_SECRET_KEY=dev_secret_key_change_in_production

# Service URLs (internal Docker network only)
GATEWAY_URL=http://gateway:8000
REQUEST_SERVICE_URL=http://request-service:8000/api/v1/requests/
NOTIFICATION_SERVICE_URL=http://notification-service:8000
LOCATION_SERVICE_URL=http://location-service:8000/api/v1/validate/
TICKET_SERVICE_URL=http://ticket-service:8000
POSTGRES_URL=postgresql://civic_user:civic_pass@postgres:5432/civic_db
RABBITMQ_URL=amqp://civic_user:civic_pass@rabbitmq:5672/
