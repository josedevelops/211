# WARNING: Copy this file to .env and fill in your values
# Never commit .env to git

POSTGRES_USER=change_me
POSTGRES_PASSWORD=change_me
POSTGRES_DB=civic_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

RABBITMQ_USER=change_me
RABBITMQ_PASSWORD=change_me
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

APP_ENV=development
SERVICE_PORT=8000
JWT_SECRET_KEY=change_me_in_production

GATEWAY_URL=http://gateway:8000
REQUEST_SERVICE_URL=http://request-service:8000/api/v1/requests/
NOTIFICATION_SERVICE_URL=http://notification-service:8000
LOCATION_SERVICE_URL=http://location-service:8000/api/v1/validate/
TICKET_SERVICE_URL=http://ticket-service:8000
POSTGRES_URL=postgresql://change_me:change_me@postgres:5432/civic_db
RABBITMQ_URL=amqp://change_me:change_me@rabbitmq:5672/
